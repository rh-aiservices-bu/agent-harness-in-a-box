# Copy to .env and fill in your values.
# These are used inside sandboxes - do NOT commit .env to git.

# LiteLLM API configuration
LITELLM_BASE_URL=https://your-litellm-endpoint.example.com/v1
LITELLM_API_KEY=sk-your-key-here
LITELLM_MODEL=gpt-oss-120b
LITELLM_MODEL_SMALL=llama-scout-17b

# MLflow (RHOAI) - requires OCP token + X-Mlflow-Workspace header
MLFLOW_TRACKING_URI=https://rh-ai.apps.example.com/mlflow
MLFLOW_WORKSPACE=openshell

# OpenShift cluster
OCP_API=https://api.your-cluster.example.com:6443
OCP_APPS_DOMAIN=apps.your-cluster.example.com
