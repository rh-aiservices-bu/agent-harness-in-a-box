# Copy to .env and fill in your values.
# These are used inside sandboxes - do NOT commit .env to git.

# LiteLLM / OpenAI-compatible API
LITELLM_BASE_URL=https://your-litellm-endpoint.example.com/v1
LITELLM_API_KEY=sk-your-key-here

# Anthropic (for Claude Code / OpenCode with Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# MLflow tracing
MLFLOW_TRACKING_URI=http://mlflow.openshell.svc.cluster.local:5000
MLFLOW_EXPERIMENT_NAME=opencode-sandbox
