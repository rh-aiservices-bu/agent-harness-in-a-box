# Claude Code agent for OpenShell sandbox
#
# Flavor image built on the shared openshell-base.
# Adds Node.js and Claude Code CLI.
#
# Build:
#   podman build --platform linux/amd64 -t claude-code-sandbox:latest -f Containerfile.claude-code .

FROM quay.io/hmoghani/openshell-base:latest

USER 0

# Node.js runtime (from UBI repos)
RUN microdnf install -y --nodocs nodejs npm && \
    microdnf clean all && \
    rm -rf /var/cache/yum

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Verify
RUN claude --version || true

USER 1001
WORKDIR /workspace
ENV AGENT_NAME=claude-code
