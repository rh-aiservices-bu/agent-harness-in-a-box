# Permissive sandbox policy - full development access.
# Allows inference, package registries, GitHub (full access), direct AI APIs,
# and RHOAI MLflow tracing. Still enforces an allowlist - unrecognized hosts
# are blocked.
#
# Use case: trusted coding agents (Claude Code) needing broad access.
#
# Template: replace __OCP_APPS_DOMAIN__ before applying.
# Apply:  openshell policy set [--wait] <sandbox-name> --policy <rendered-file>
# Test:   bash test-sandbox-security.sh <sandbox-name>

version: 1

filesystem_policy:
  include_workdir: true
  read_only:
    - /usr
    - /lib
    - /lib64
    - /bin
    - /sbin
    - /proc
    - /dev/urandom
    - /etc
    - /opt
    - /var/log
  read_write:
    - /sandbox
    - /workspace
    - /tmp
    - /home/sandbox
    - /dev/null
    - /dev/zero

landlock:
  compatibility: best_effort

process:
  run_as_user: sandbox
  run_as_group: sandbox

network_policies:

  litellm_maas:
    name: "LiteLLM MaaS"
    endpoints:
      - host: "maas-rhdp.apps.maas.redhatworkshops.io"
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
      - host: "*.redhatworkshops.io"
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/python3 }
      - { path: "/sandbox/.uv/python/**" }
      - { path: /usr/bin/node }
      - { path: /usr/local/bin/claude }

  npm_registry:
    name: "npm"
    endpoints:
      - host: registry.npmjs.org
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/node }
      - { path: /usr/local/bin/opencode }

  pypi:
    name: "PyPI"
    endpoints:
      - host: pypi.org
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
      - host: files.pythonhosted.org
        port: 443
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/python3 }
      - { path: "/sandbox/.uv/python/**" }
      - { path: /usr/local/bin/uv }

  github:
    name: "GitHub (full access)"
    endpoints:
      - host: github.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
      - host: api.github.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
      - host: "*.githubusercontent.com"
        port: 443
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/git }
      - { path: /usr/bin/node }
      - { path: /usr/local/bin/claude }

  anthropic_api:
    name: "Anthropic API"
    endpoints:
      - host: api.anthropic.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/node }
      - { path: /usr/local/bin/claude }

  openai_api:
    name: "OpenAI API"
    endpoints:
      - host: api.openai.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/node }
      - { path: /usr/bin/codex }

  google_vertex:
    name: "Google Vertex AI"
    endpoints:
      - host: "*.googleapis.com"
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/node }

  opencode_updates:
    name: "OpenCode (read-only)"
    endpoints:
      - host: opencode.ai
        port: 443
        protocol: rest
        enforcement: enforce
        access: read-only
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/node }
      - { path: /usr/local/bin/opencode }

  openshift_oauth:
    name: "OpenShift OAuth (for RHOAI auth)"
    endpoints:
      - host: "oauth-openshift.__OCP_APPS_DOMAIN__"
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }

  mlflow_rhoai:
    name: "RHOAI MLflow"
    endpoints:
      - host: "mlflow.redhat-ods-applications.svc.cluster.local"
        port: 8443
        protocol: rest
        enforcement: enforce
        access: full
      - host: "mlflow-redhat-ods-applications.__OCP_APPS_DOMAIN__"
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/python3 }
      - { path: "/sandbox/.uv/python/**" }
