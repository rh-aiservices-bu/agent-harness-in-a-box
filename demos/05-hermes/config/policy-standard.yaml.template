# Standard sandbox policy for Hermes agent.
# Allows inference (LiteLLM), PyPI (skill installs), GitHub (read-only),
# NousResearch (model catalog), and RHOAI MLflow tracing.
# Blocks direct AI APIs, web browsing, and GitHub write operations.
#
# Template: replace __OCP_APPS_DOMAIN__ before applying.
# Apply:  openshell policy set [--wait] <sandbox-name> --policy <rendered-file>
# Test:   bash test-sandbox-security.sh <sandbox-name>

version: 1

filesystem_policy:
  include_workdir: true
  read_only:
    - /usr
    - /lib
    - /lib64
    - /bin
    - /sbin
    - /proc
    - /dev/urandom
    - /etc
    - /opt
    - /var/log
  read_write:
    - /sandbox
    - /workspace
    - /tmp
    - /home/sandbox
    - /dev/null
    - /dev/zero

landlock:
  compatibility: best_effort

process:
  run_as_user: sandbox
  run_as_group: sandbox

network_policies:

  litellm_maas:
    name: "LiteLLM MaaS"
    endpoints:
      - host: "maas-rhdp.apps.maas.redhatworkshops.io"
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
      - host: "*.redhatworkshops.io"
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/python3 }
      - { path: /usr/bin/python3.12 }
      - { path: "/usr/local/bin/hermes" }
      - { path: "/sandbox/.uv/python/**" }

  pypi:
    name: "PyPI"
    endpoints:
      - host: pypi.org
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
      - host: files.pythonhosted.org
        port: 443
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/python3 }
      - { path: /usr/bin/python3.12 }
      - { path: "/sandbox/.uv/python/**" }

  github_readonly:
    name: "GitHub (read-only)"
    endpoints:
      - host: github.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: read-only
      - host: api.github.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: read-only
      - host: "*.githubusercontent.com"
        port: 443
        enforcement: enforce
        access: read-only
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/git }
      - { path: /usr/bin/python3 }

  nousresearch:
    name: "NousResearch (model catalog)"
    endpoints:
      - host: hermes-agent.nousresearch.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: read-only
      - host: nousresearch.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: read-only
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/python3 }
      - { path: "/usr/local/bin/hermes" }

  openshift_oauth:
    name: "OpenShift OAuth (for RHOAI auth)"
    endpoints:
      - host: "oauth-openshift.__OCP_APPS_DOMAIN__"
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }

  mlflow_rhoai:
    name: "RHOAI MLflow"
    endpoints:
      - host: "mlflow.redhat-ods-applications.svc.cluster.local"
        port: 8443
        protocol: rest
        enforcement: enforce
        access: full
      - host: "mlflow-redhat-ods-applications.__OCP_APPS_DOMAIN__"
        port: 443
        protocol: rest
        enforcement: enforce
        access: full
    binaries:
      - { path: /usr/bin/curl }
      - { path: /usr/bin/python3 }
      - { path: /usr/bin/python3.12 }
      - { path: "/sandbox/.uv/python/**" }
